    breaksw
case "gen_3d_merge_env:after":
    # 在此添加 gen_3d_merge_env 的后置 ECO 命令。
    breaksw
case "analysis_3d_netlist:before":
    # 在此添加 analysis_3d_netlist 的前置 ECO 命令。
    breaksw
case "analysis_3d_netlist:after":
    # 在此添加 analysis_3d_netlist 的后置 ECO 命令。
    breaksw
case "complete_check:before":
