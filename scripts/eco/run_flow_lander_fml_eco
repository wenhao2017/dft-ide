#!/bin/csh -f

# Lander FML 项目级 ECO 调度入口。
if (! $?DFT_IDE_STEP || ! $?DFT_IDE_ECO_PHASE) exit 2
set step = "$DFT_IDE_STEP"
set phase = "$DFT_IDE_ECO_PHASE"
if ("$phase" != "before" && "$phase" != "after") exit 2

switch ("$step")
case "create_project":
case "gen_design_info":
case "gen_plan_env":
case "release_plan":
case "gen_fml_env":
case "run_fml":
case "upload_fml_database_pre":
case "upload_fml_database":
case "gen_report":
    # 请按需拆分独立的 case 分支，并添加领域或项目 ECO 调用。
    breaksw
default:
    echo "[DFT IDE] 未知的 Lander FML ECO Step: $step"
    exit 2
endsw
exit 0
