#!/bin/csh -f

# Hibist 项目级 ECO 调度入口。
# 请在对应的 Step 和执行阶段分支中添加领域或项目 ECO 命令。

if (! $?DFT_IDE_STEP || ! $?DFT_IDE_ECO_PHASE) then
    echo "[DFT IDE] 未设置 DFT_IDE_STEP 或 DFT_IDE_ECO_PHASE。"
    exit 2
endif

set step = "$DFT_IDE_STEP"
set phase = "$DFT_IDE_ECO_PHASE"
if ("$phase" != "before" && "$phase" != "after") then
    echo "[DFT IDE] 不支持的 Hibist ECO 阶段: $phase"
    exit 2
endif

switch ("$step")
case "gen_analysis_env":
    # 在此添加 gen_analysis_env 的前置/后置 ECO 命令。
    breaksw
case "run_analysis":
    # 在此添加 run_analysis 的前置/后置 ECO 命令。
    breaksw
case "gen_insert_env":
    # 在此添加 gen_insert_env 的前置/后置 ECO 命令。
    breaksw
case "run_insert":
    # 在此添加 run_insert 的前置/后置 ECO 命令。
    breaksw
case "gen_build_env":
    # 在此添加 gen_build_env 的前置/后置 ECO 命令。
    breaksw
case "run_build":
    # 在此添加 run_build 的前置/后置 ECO 命令。
    breaksw
case "gen_syn_env":
    # 在此添加 gen_syn_env 的前置/后置 ECO 命令。
    breaksw
case "run_syn":
    # 在此添加 run_syn 的前置/后置 ECO 命令。
    breaksw
case "gen_fml_env":
    # 在此添加 gen_fml_env 的前置/后置 ECO 命令。
    breaksw
case "run_fml":
    # 在此添加 run_fml 的前置/后置 ECO 命令。
    breaksw
case "gen_sim_env":
    # 在此添加 gen_sim_env 的前置/后置 ECO 命令。
    breaksw
case "run_sim":
    # 在此添加 run_sim 的前置/后置 ECO 命令。
    breaksw
case "release":
    # 在此添加 release 的前置/后置 ECO 命令。
    breaksw
default:
    echo "[DFT IDE] 未知的 Hibist ECO Step: $step"
    exit 2
endsw

exit 0
