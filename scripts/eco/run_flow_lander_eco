#!/bin/csh -f

# Lander 通用项目级 ECO 调度入口。
# 设置 DFT_IDE_LANDER_MODE 后，Mode 流程将调用对应的
# run_flow_lander_<mode>_eco；跨 Mode 的通用规则可放在本文件中。

if (! $?DFT_IDE_STEP || ! $?DFT_IDE_ECO_PHASE) then
    echo "[DFT IDE] 未设置 DFT_IDE_STEP 或 DFT_IDE_ECO_PHASE。"
    exit 2
endif

set step = "$DFT_IDE_STEP"
set phase = "$DFT_IDE_ECO_PHASE"
if ("$phase" != "before" && "$phase" != "after") then
    echo "[DFT IDE] 不支持的 Lander ECO 阶段: $phase"
    exit 2
endif

# 在此添加通用 Lander ECO 调度规则；没有匹配动作时正常返回 0。
switch ("${step}:${phase}")
case "prepare_workspace:before":
    # 在此添加 prepare_workspace 的前置 ECO 命令。
    breaksw
case "prepare_workspace:after":
    # 在此添加 prepare_workspace 的后置 ECO 命令。
    breaksw
case "load_config:before":
    # 在此添加 load_config 的前置 ECO 命令。
    breaksw
case "load_config:after":
    # 在此添加 load_config 的后置 ECO 命令。
    breaksw
case "check_env:before":
    # 在此添加 check_env 的前置 ECO 命令。
    breaksw
case "check_env:after":
    # 在此添加 check_env 的后置 ECO 命令。
    breaksw
case "submit_mode:before":
    # 在此添加 submit_mode 的前置 ECO 命令。
    breaksw
case "submit_mode:after":
    # 在此添加 submit_mode 的后置 ECO 命令。
    breaksw
case "collect_result:before":
    # 在此添加 collect_result 的前置 ECO 命令。
    breaksw
case "collect_result:after":
    # 在此添加 collect_result 的后置 ECO 命令。
    breaksw
case "parse_report:before":
    # 在此添加 parse_report 的前置 ECO 命令。
    breaksw
case "parse_report:after":
    # 在此添加 parse_report 的后置 ECO 命令。
    breaksw
case "publish_dashboard:before":
    # 在此添加 publish_dashboard 的前置 ECO 命令。
    breaksw
case "publish_dashboard:after":
    # 在此添加 publish_dashboard 的后置 ECO 命令。
    breaksw
default:
    echo "[DFT IDE] 未知的 ECO 调度组合: step=$step phase=$phase"
    exit 2
endsw

exit 0
