#!/bin/csh -f

# Lander prune 项目级 ECO 调度入口。
if (! $?DFT_IDE_STEP || ! $?DFT_IDE_ECO_PHASE || ! $?DFT_IDE_STAGE) exit 2
set step = "$DFT_IDE_STEP"
set phase = "$DFT_IDE_ECO_PHASE"
set stage = "$DFT_IDE_STAGE"
if ("$phase" != "before" && "$phase" != "after") exit 2

switch ("${step}:${phase}")
case "create_project:before":
    # 在此添加 create_project 的前置 ECO 命令。
    breaksw
case "create_project:after":
    # 在此添加 create_project 的后置 ECO 命令。
    breaksw
case "gen_design_info:before":
    # 在此添加 gen_design_info 的前置 ECO 命令。
    breaksw
case "gen_design_info:after":
    # 在此添加 gen_design_info 的后置 ECO 命令。
    breaksw
case "gen_prune_env:before":
    # 在此添加 gen_prune_env 的前置 ECO 命令。
    breaksw
case "gen_prune_env:after":
    # 在此添加 gen_prune_env 的后置 ECO 命令。
    breaksw
case "run_prune:before":
    # 在此添加 run_prune 的前置 ECO 命令。
    breaksw
case "run_prune:after":
    # 在此添加 run_prune 的后置 ECO 命令。
    breaksw
default:
    echo "[DFT IDE] 未知的 ECO 调度组合: step=$step phase=$phase"
    exit 2
endsw
exit 0
