#!/bin/csh -f

# Lander ATPG 项目级 ECO 调度入口。

if (! $?DFT_IDE_STEP || ! $?DFT_IDE_ECO_PHASE) then
    echo "[DFT IDE] 未设置 DFT_IDE_STEP 或 DFT_IDE_ECO_PHASE。"
    exit 2
endif

set step = "$DFT_IDE_STEP"
set phase = "$DFT_IDE_ECO_PHASE"
if ("$phase" != "before" && "$phase" != "after") then
    echo "[DFT IDE] 不支持的 Lander ATPG ECO 阶段: $phase"
    exit 2
endif

switch ("$step")
case "create_project":
case "gen_design_info":
case "gen_plan_env":
case "release_plan":
case "gen_atpg_setting":
case "gen_pdl_env":
case "gen_atpg_env_pre":
case "gen_atpg_env":
case "gen_crg_env":
case "run_crg_gen":
case "run_atpg":
case "gen_all_scan_env":
case "run_all_scan":
case "delivery_data":
case "sed_3d_tb":
case "gen_sim_env":
case "run_sim":
    # 某个 Step 需要 ECO 时，请拆分成独立的 case 分支并添加调用命令。
    breaksw
default:
    echo "[DFT IDE] 未知的 Lander ATPG ECO Step: $step"
    exit 2
endsw

exit 0
