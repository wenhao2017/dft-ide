+
+分别执行以下脚本 powershell
+.\tools\scripts\setup-1.85.1.ps1
+.\tools\scripts\debug-1.85.1.ps1
+
+vscode 运行调试 切换配置（"Attach DFT IDE Extension (VSCode 1.85.1)）
+运行Debug
+
+调试的 vscode 中 （ctrl+shift+p -> Restart Extension host）
+Extension 重载
diff --git a/tools/scripts/debug-1.85.1.ps1 b/tools/scripts/debug-1.85.1.ps1
new file mode 100644
index 0000000..cf39a12
--- /dev/null
+++ b/tools/scripts/debug-1.85.1.ps1
@@ -0,0 +1,21 @@
+$ErrorActionPreference = "Stop"
+
+$Root = (Resolve-Path "$PSScriptRoot\..\..").Path
+
+$CodeExe = Join-Path $Root "tools\vscode-1.85.1\Code.exe"
+
+$UserDataDir = Join-Path $Root ".vscode-test\user-data-1.85.1"
+$ExtensionsDir = Join-Path $Root ".vscode-test\extensions-1.85.1"
