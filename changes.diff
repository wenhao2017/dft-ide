+export async function getNormalizeTablePath(flow: string) : Promise<{ designTree: string, normTable: string }>{
+  try {
+    // 根据flow 获取归一化表格文件和design tree, 归一化表格配置都在common.json中，所以传参'common'
+    const filePath = resolveConfigPath('common');
