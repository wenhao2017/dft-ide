+function getExcelComMergeScript(): string {
+  return String.raw`
+param([string]$InputJson)
+$ErrorActionPreference = "Stop"
+$payload = Get-Content -Raw -LiteralPath $InputJson | ConvertFrom-Json
+$artifact = $payload.artifact
+$strategy = [string]$payload.strategy
+$decisionMap = @{}
+foreach ($d in @($payload.decisions)) { $decisionMap[[string]$d.id] = $d }
+function Enc([string]$s) {
+  $bytes = [System.Text.Encoding]::UTF8.GetBytes($s)
+  return [Convert]::ToBase64String($bytes).TrimEnd('=').Replace('+','-').Replace('/','_')
+}
+function DiffId([string]$fileType, [string]$sheet, [string]$key, [string]$field) {
+  return "$fileType|$(Enc $sheet)|$(Enc $key)|$(Enc $field)"
+}
+function CellText($cell) {
+  if ($null -eq $cell.Value2) { return "" }
+  return [string]$cell.Text
+}
+function KeyIndex($ws, [int]$cols) {
+  $preferred = @("key","id","name","design_name","pin_name","module","module_name")
+  for ($c = 1; $c -le $cols; $c++) {
+    $h = (CellText $ws.Cells.Item(1,$c)).Trim().ToLower()
+    if ($preferred -contains $h) { return $c }
+  }
+  return 1
+}
+function BuildModel($ws) {
+  $used = $ws.UsedRange
+  $rows = [int]$used.Rows.Count
+  $cols = [int]$used.Columns.Count
+  if ($rows -lt 1) { $rows = 1 }
+  if ($cols -lt 1) { $cols = 1 }
+  $keyCol = KeyIndex $ws $cols
+  $keys = New-Object System.Collections.ArrayList
+  $rowByKey = @{}
+  for ($r = 2; $r -le $rows; $r++) {
+    $raw = (CellText $ws.Cells.Item($r,$keyCol)).Trim()
+    if (-not $raw) {
+      for ($c = 1; $c -le $cols; $c++) {
+        $raw = (CellText $ws.Cells.Item($r,$c)).Trim()
+        if ($raw) { break }
+      }
+    }
+    if (-not $raw) { continue }
+    $key = $raw
+    $suffix = 2
+    while ($rowByKey.ContainsKey($key)) {
+      $key = "$raw#$suffix"
+      $suffix++
+    }
+    [void]$keys.Add($key)
+    $rowByKey[$key] = $r
+  }
+  return @{ rows=$rows; cols=$cols; keyCol=$keyCol; keys=$keys; rowByKey=$rowByKey }
+}
+function Choice([string]$id, [string]$auto) {
+  if ($strategy -eq "autoMerge") { return $auto }
+  if ($decisionMap.ContainsKey($id)) { return [string]$decisionMap[$id].choice }
+  return $auto
+}
+function InsertPos($sourceKeys, [string]$rowKey, $targetModel, $inserted, [int]$rowCount) {
+  $idx = [array]::IndexOf($sourceKeys.ToArray(), $rowKey)
+  for ($i = $idx - 1; $i -ge 0; $i--) {
+    $k = [string]$sourceKeys[$i]
+    if ($inserted.ContainsKey($k)) { return [int]$inserted[$k] + 1 }
+    if ($targetModel.rowByKey.ContainsKey($k)) { return [int]$targetModel.rowByKey[$k] + 1 }
+  }
+  for ($i = $idx + 1; $i -lt $sourceKeys.Count; $i++) {
+    $k = [string]$sourceKeys[$i]
+    if ($inserted.ContainsKey($k)) { return [int]$inserted[$k] }
+    if ($targetModel.rowByKey.ContainsKey($k)) { return [int]$targetModel.rowByKey[$k] }
+  }
+  return $rowCount + 1
+}
+$excel = New-Object -ComObject Excel.Application
+$excel.Visible = $false
+$excel.DisplayAlerts = $false
+$src = $null
+$tgt = $null
+try {
+  $src = $excel.Workbooks.Open($artifact.source)
+  $tgt = $excel.Workbooks.Open($artifact.target)
+  foreach ($srcWs in @($src.Worksheets)) {
+    $sheetName = [string]$srcWs.Name
+    $tgtWs = $null
+    foreach ($w in @($tgt.Worksheets)) { if ([string]$w.Name -eq $sheetName) { $tgtWs = $w; break } }
+    $sheetId = DiffId $artifact.key $sheetName $sheetName ""
+    if ($null -eq $tgtWs) {
+      if ((Choice $sheetId "source") -eq "source") { $srcWs.Copy($null, $tgt.Worksheets.Item($tgt.Worksheets.Count)) }
+      continue
+    }
+    $sm = BuildModel $srcWs
+    $tm = BuildModel $tgtWs
+    $inserted = @{}
+    foreach ($rowKey in @($sm.keys)) {
+      $srow = [int]$sm.rowByKey[$rowKey]
+      if (-not $tm.rowByKey.ContainsKey($rowKey)) {
+        $rowId = DiffId $artifact.key $sheetName $rowKey ""
+        if ((Choice $rowId "source") -ne "source") { continue }
+        $insertAt = InsertPos $sm.keys $rowKey $tm $inserted ([int]$tgtWs.UsedRange.Rows.Count)
+        $tgtWs.Rows.Item($insertAt).Insert() | Out-Null
+        $srcWs.Rows.Item($srow).Copy($tgtWs.Rows.Item($insertAt)) | Out-Null
+        $inserted[$rowKey] = $insertAt
+        foreach ($k in @($tm.rowByKey.Keys)) { if ([int]$tm.rowByKey[$k] -ge $insertAt) { $tm.rowByKey[$k] = [int]$tm.rowByKey[$k] + 1 } }
+        continue
+      }
+      $trow = [int]$tm.rowByKey[$rowKey]
+      $maxCols = [Math]::Max([int]$sm.cols, [int]$tm.cols)
+      for ($c = 1; $c -le $maxCols; $c++) {
+        $sv = CellText $srcWs.Cells.Item($srow,$c)
+        $tv = CellText $tgtWs.Cells.Item($trow,$c)
+        if ($sv -eq $tv) { continue }
+        $field = CellText $srcWs.Cells.Item(1,$c)
+        if (-not $field) { $field = CellText $tgtWs.Cells.Item(1,$c) }
+        if (-not $field) { $field = "Column $c" }
+        $id = DiffId $artifact.key $sheetName "$rowKey::$($c-1)" $field
+        $choice = Choice $id "source"
+        if ($choice -eq "source") {
+          $tgtWs.Cells.Item($trow,$c).Value2 = $srcWs.Cells.Item($srow,$c).Value2
+        } elseif ($choice -eq "custom") {
+          $tgtWs.Cells.Item($trow,$c).Value2 = [string]$decisionMap[$id].customValue
+        }
+      }
+    }
+  }
+  $tgt.Save()
+} finally {
+  if ($src) { $src.Close($false) | Out-Null }
+  if ($tgt) { $tgt.Close($true) | Out-Null }
+  $excel.Quit() | Out-Null
+  [System.Runtime.InteropServices.Marshal]::ReleaseComObject($excel) | Out-Null
+}
+`;
+}
