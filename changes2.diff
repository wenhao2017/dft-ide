+
+  // 回填：从文件读到 savedData 后填入表单
+  useEffect(() => {
+    if (!savedData) return;
+    const source = (savedData.step2 as Record<string, unknown> | undefined) ?? savedData;
+    // 任务配置子表单
+    if (source.step2Task) {
+      taskForm.setFieldsValue(source.step2Task);
