+            continue
+        tgt_sheet = target_sheets.getByName(sheet_name)
+        sm, tm = build_model(src_sheet), build_model(tgt_sheet)
+        inserted = {}
+        for row_key in list(sm["keys"]):
+            srow = sm["row_by_key"][row_key]
+            if row_key not in tm["row_by_key"]:
+                row_id = diff_id(artifact["key"], sheet_name, row_key, "")
+                if choice(row_id, "source") != "source":
+                    continue
+                at = insert_pos(sm["keys"], row_key, tm, inserted, used_size(tgt_sheet)[0])
+                tgt_sheet.Rows.insertByIndex(at, 1)
+                cols = max(sm["cols"], tm["cols"])
+                src_range = src_sheet.getCellRangeByPosition(0, srow, cols - 1, srow)
+                tgt_range = tgt_sheet.getCellRangeByPosition(0, at, cols - 1, at)
+                tgt_range.setDataArray(src_range.getDataArray())
+                inserted[row_key] = at
+                for k, v in list(tm["row_by_key"].items()):
+                    if v >= at: tm["row_by_key"][k] = v + 1
+                continue
+            trow = tm["row_by_key"][row_key]
+            for c in range(max(sm["cols"], tm["cols"])):
+                sv, tv = cell_text(src_sheet, srow, c), cell_text(tgt_sheet, trow, c)
+                if sv == tv: continue
+                field = cell_text(src_sheet, 0, c) or cell_text(tgt_sheet, 0, c) or f"Column {c+1}"
+                item_id = diff_id(artifact["key"], sheet_name, f"{row_key}::{c}", field)
+                selected = choice(item_id, "source")
+                if selected == "source":
+                    tgt_sheet.getCellByPosition(c, trow).Formula = src_sheet.getCellByPosition(c, srow).Formula
+                elif selected == "custom":
+                    tgt_sheet.getCellByPosition(c, trow).String = str(decisions.get(item_id, {}).get("customValue", ""))
+    tgt.store()
+    src.close(True); tgt.close(True)
+finally:
+    try: proc.terminate()
+    except Exception: pass
+`;
 }
 
 export function deactivate() {}
