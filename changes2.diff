+function buildWorkbookSheetModels(workbook: XLSX.WorkBook): Map<string, WorkbookSheetModel> {
+  const models = new Map<string, WorkbookSheetModel>();
+  for (const sheetName of workbook.SheetNames) {
+    const sheet = workbook.Sheets[sheetName];
+    const rows = normalizeWorksheetRows(XLSX.utils.sheet_to_json<string[]>(sheet, { header: 1, defval: '', blankrows: false }));
+    if (rows.length === 0) {
+      models.set(sheetName, { name: sheetName, rows: [], headers: [], rowByKey: new Map() });
+      continue;
+    }
+    const headers = rows[0].map((value, index) => value || `Column ${index + 1}`);
+    const keyIndex = findKeyColumnIndex(headers);
+    const rowByKey = new Map<string, { rowIndex: number; values: string[] }>();
+    rows.slice(1).forEach((row, offset) => {
+      if (row.every((value) => value === '')) {
+        return;
+      }
+      const rawKey = (row[keyIndex] || row.find((value) => value !== '') || `row-${offset + 2}`).trim();
+      const key = makeUniqueRowKey(rowByKey, rawKey || `row-${offset + 2}`);
+      rowByKey.set(key, { rowIndex: offset + 1, values: row });
+    });
+    models.set(sheetName, { name: sheetName, rows, headers, rowByKey });
+  }
+  return models;
+}
+
+function buildExcelJsWorkbookModels(workbook: ExcelJS.Workbook): Map<string, WorkbookSheetModel> {
+  const models = new Map<string, WorkbookSheetModel>();
+  workbook.eachSheet((worksheet) => {
+    const rows: string[][] = [];
+    worksheet.eachRow({ includeEmpty: false }, (row) => {
+      const values: string[] = [];
+      for (let columnIndex = 1; columnIndex <= Math.max(row.cellCount, worksheet.columnCount); columnIndex += 1) {
+        values[columnIndex - 1] = normalizeExcelCellValue(row.getCell(columnIndex).value);
+      }
+      rows[row.number - 1] = values;
+    });
+
+    const compactRows = rows.map((row) => row ?? []);
+    const firstNonEmpty = compactRows.findIndex((row) => row.some((value) => value !== ''));
+    if (firstNonEmpty < 0) {
+      models.set(worksheet.name, { name: worksheet.name, rows: [], headers: [], rowByKey: new Map() });
+      return;
+    }
+
+    const headers = (compactRows[firstNonEmpty] ?? []).map((value, index) => value || `Column ${index + 1}`);
+    const keyIndex = findKeyColumnIndex(headers);
+    const rowByKey = new Map<string, { rowIndex: number; values: string[] }>();
+    compactRows.forEach((row, rowIndex) => {
+      if (rowIndex <= firstNonEmpty || row.every((value) => value === '')) {
+        return;
+      }
+      const rawKey = (row[keyIndex] || row.find((value) => value !== '') || `row-${rowIndex + 1}`).trim();
+      const key = makeUniqueRowKey(rowByKey, rawKey || `row-${rowIndex + 1}`);
+      rowByKey.set(key, { rowIndex, values: row });
+    });
+
+    models.set(worksheet.name, { name: worksheet.name, rows: compactRows, headers, rowByKey });
+  });
+  return models;
+}
+
+function normalizeWorksheetRows(rows: string[][]): string[][] {
+  return rows.map((row) => row.map((value) => normalizeCellValue(value)));
+}
+
+function normalizeCellValue(value: unknown): string {
+  if (value === null || value === undefined) {
+    return '';
+  }
+  if (value instanceof Date) {
+    return value.toISOString();
+  }
+  return String(value);
+}
+
+function normalizeExcelCellValue(value: ExcelJS.CellValue): string {
+  if (value === null || value === undefined) {
+    return '';
+  }
+  if (value instanceof Date) {
+    return value.toISOString();
+  }
+  if (typeof value === 'object') {
+    if ('result' in value && value.result !== undefined) {
+      return normalizeCellValue(value.result);
+    }
+    if ('text' in value && value.text !== undefined) {
+      return normalizeCellValue(value.text);
+    }
+    if ('richText' in value && Array.isArray(value.richText)) {
+      return value.richText.map((part) => part.text).join('');
+    }
+    if ('hyperlink' in value && 'text' in value) {
+      return normalizeCellValue(value.text);
+    }
+    return JSON.stringify(value);
+  }
+  return String(value);
+}
+
+function findKeyColumnIndex(headers: string[]): number {
+  const normalized = headers.map((header) => header.trim().toLowerCase());
+  const preferred = ['key', 'id', 'name', 'design_name', 'pin_name', 'module', 'module_name'];
+  for (const key of preferred) {
+    const index = normalized.indexOf(key);
+    if (index >= 0) {
+      return index;
+    }
+  }
+  return 0;
+}
+
+function makeUniqueRowKey(rowByKey: Map<string, unknown>, rawKey: string): string {
+  let key = rawKey;
+  let suffix = 2;
+  while (rowByKey.has(key)) {
+    key = `${rawKey}#${suffix}`;
+    suffix += 1;
+  }
+  return key;
+}
+
+function findInsertRowNumber(
+  sourceKeys: string[],
+  insertedKey: string,
+  targetSheet: WorkbookSheetModel,
+  insertedKeys: Map<string, number>,
+  fallbackRowCount: number
+): number {
+  const sourceIndex = sourceKeys.indexOf(insertedKey);
+  for (let index = sourceIndex - 1; index >= 0; index -= 1) {
+    const key = sourceKeys[index];
+    const insertedRow = insertedKeys.get(key);
+    if (insertedRow !== undefined) {
+      return insertedRow + 1;
+    }
+    const targetRow = targetSheet.rowByKey.get(key);
+    if (targetRow) {
+      return targetRow.rowIndex + 2;
+    }
+  }
+  for (let index = sourceIndex + 1; index < sourceKeys.length; index += 1) {
+    const key = sourceKeys[index];
+    const insertedRow = insertedKeys.get(key);
+    if (insertedRow !== undefined) {
+      return insertedRow;
+    }
+    const targetRow = targetSheet.rowByKey.get(key);
+    if (targetRow) {
+      return targetRow.rowIndex + 1;
+    }
+  }
+  return fallbackRowCount + 1;
+}
+
+function shiftInsertedRows(insertedKeys: Map<string, number>, insertAt: number, insertedKey: string): void {
+  for (const [key, rowNumber] of insertedKeys.entries()) {
+    if (key !== insertedKey && rowNumber >= insertAt) {
+      insertedKeys.set(key, rowNumber + 1);
+    }
+  }
+}
+
+function shiftWorkbookModelRows(sheet: WorkbookSheetModel, insertAt: number): void {
+  for (const row of sheet.rowByKey.values()) {
+    if (row.rowIndex + 1 >= insertAt) {
+      row.rowIndex += 1;
+    }
+  }
+}
+
+function copyWorksheet(source: ExcelJS.Worksheet, target: ExcelJS.Worksheet): void {
+  target.properties = { ...source.properties };
+  target.views = source.views.map((view) => ({ ...view }));
+  source.columns.forEach((column, index) => {
+    const targetColumn = target.getColumn(index + 1);
+    if (column.width !== undefined) {
+      targetColumn.width = column.width;
+    }
+    if (column.hidden !== undefined) {
+      targetColumn.hidden = column.hidden;
+    }
+    if (column.outlineLevel !== undefined) {
+      targetColumn.outlineLevel = column.outlineLevel;
+    }
+    if (column.style) {
+      targetColumn.style = clonePlain(column.style);
+    }
+  });
+  source.eachRow({ includeEmpty: true }, (sourceRow) => {
+    const targetRow = target.getRow(sourceRow.number);
+    copyRow(sourceRow, targetRow);
+  });
+  for (const range of getWorksheetMergeRanges(source)) {
+    target.mergeCells(range);
+  }
+}
+
+function copyRow(sourceRow: ExcelJS.Row, targetRow: ExcelJS.Row): void {
+  targetRow.height = sourceRow.height;
+  targetRow.hidden = sourceRow.hidden;
+  targetRow.outlineLevel = sourceRow.outlineLevel;
+  sourceRow.eachCell({ includeEmpty: true }, (sourceCell, columnNumber) => {
+    const targetCell = targetRow.getCell(columnNumber);
+    copyCell(sourceCell, targetCell);
+  });
+  targetRow.commit();
+}
+
+function copyCell(sourceCell: ExcelJS.Cell, targetCell: ExcelJS.Cell): void {
+  targetCell.value = cloneExcelCellValue(sourceCell.value);
+
+  targetCell.style = clonePlain(sourceCell.style);
+  targetCell.numFmt = sourceCell.numFmt;
+  targetCell.font = clonePlain(sourceCell.font);
+  targetCell.alignment = clonePlain(sourceCell.alignment);
+  targetCell.border = clonePlain(sourceCell.border);
+  targetCell.fill = clonePlain(sourceCell.fill);
+  targetCell.protection = clonePlain(sourceCell.protection);
+}
+
+function cloneExcelCellValue(value: ExcelJS.CellValue): ExcelJS.CellValue {
+  return clonePlain(value);
+}
+
+function clonePlain<T>(value: T): T {
+  if (value === undefined || value === null) {
+    return value;
+  }
+  if (value instanceof Date) {
+    return new Date(value.getTime()) as T;
+  }
+  if (typeof value !== 'object') {
+    return value;
+  }
+  return JSON.parse(JSON.stringify(value)) as T;
+}
+
+function getWorksheetMergeRanges(worksheet: ExcelJS.Worksheet): string[] {
+  const model = worksheet.model as unknown as { merges?: string[] };
+  return Array.isArray(model.merges) ? model.merges : [];
+}
+
+function makeWorkbookDiffItem(
+  artifact: CommonSyncArtifact,
+  sheetName: string,
+  key: string,
+  fieldName: string,
+  type: CommonSyncDiffItem['type'],
+  sourceVal: string,
+  targetVal: string
+): CommonSyncDiffItem {
+  return {
+    id: makeWorkbookDiffId(artifact.key, sheetName, key, fieldName),
+    fileType: artifact.key,
+    fileName: path.basename(artifact.source),
+    sheetName,
+    key,
+    fieldName,
+    type,
+    sourceVal,
+    targetVal,
+  };
+}
+
+function makeWorkbookDiffId(fileType: CommonSyncArtifact['key'], sheetName: string, key: string, fieldName: string): string {
+  return `${fileType}|${encodeDiffPart(sheetName)}|${encodeDiffPart(key)}|${encodeDiffPart(fieldName)}`;
+}
+
+function encodeDiffPart(value: string): string {
+  return Buffer.from(value, 'utf-8').toString('base64url');
+}
+
+function resolveWorkbookChoice(
+  strategy: string,
+  decision: { choice: 'source' | 'target' | 'custom'; customValue?: string } | undefined,
+  autoChoice: 'source' | 'target'
+): 'source' | 'target' | 'custom' {
+  if (strategy === 'autoMerge') {
+    return autoChoice;
+  }
+  return decision?.choice ?? autoChoice;
+}
+
+function rowToDisplay(row: string[]): string {
+  return row.filter((value) => value !== '').join(', ');
+}
+
+function appendSheet(workbook: XLSX.WorkBook, sheetName: string, rows: string[][]): void {
+  const worksheet = XLSX.utils.aoa_to_sheet(rows);
+  XLSX.utils.book_append_sheet(workbook, worksheet, sanitizeSheetName(sheetName));
+}
+
+function sanitizeSheetName(sheetName: string): string {
+  return sheetName.replace(/[:\\/?*\[\]]/g, '_').slice(0, 31) || 'Sheet1';
+}
+
+function getWorkbookBookType(filePath: string): XLSX.BookType {
+  return path.extname(filePath).toLowerCase() === '.xls' ? 'xls' : 'xlsx';
+}
+
+async function writeTempJson(data: unknown): Promise<string> {
