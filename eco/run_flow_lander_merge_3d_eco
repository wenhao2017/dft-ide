#!/bin/csh -f

# Project-level Lander merge 3D ECO dispatcher.
if (! $?DFT_IDE_STEP || ! $?DFT_IDE_ECO_PHASE) exit 2
set step = "$DFT_IDE_STEP"
set phase = "$DFT_IDE_ECO_PHASE"
if ("$phase" != "before" && "$phase" != "after") exit 2

switch ("$step")
case "create_project":
case "gen_design_info":
case "gen_3d_merge_env":
case "analysis_3d_netlist":
case "complete_check":
case "run_3d_merge":
case "delivery_data":
    # Split into dedicated case blocks and add project/domain ECO calls as needed.
    breaksw
default:
    echo "[DFT IDE] Unknown Lander merge 3D ECO step: $step"
    exit 2
endsw
exit 0
