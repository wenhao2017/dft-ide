#!/bin/csh -f

# Lander merge 3D 项目级 ECO 调度入口。
if (! $?DFT_IDE_STEP || ! $?DFT_IDE_ECO_PHASE) exit 2
set step = "$DFT_IDE_STEP"
set phase = "$DFT_IDE_ECO_PHASE"
if ("$phase" != "before" && "$phase" != "after") exit 2

switch ("$step")
case "create_project":
case "gen_design_info":
case "gen_3d_merge_env":
case "analysis_3d_netlist":
case "complete_check":
case "run_3d_merge":
case "delivery_data":
    # 请按需拆分独立的 case 分支，并添加领域或项目 ECO 调用。
    breaksw
default:
    echo "[DFT IDE] 未知的 Lander merge 3D ECO Step: $step"
    exit 2
endsw
exit 0
