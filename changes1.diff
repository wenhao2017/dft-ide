+
+function mergeXlsxWorksheetPreservingFormat(
+  artifact: CommonSyncArtifact,
+  sheetName: string,
+  sourceWorksheet: ExcelJS.Worksheet,
+  targetWorksheet: ExcelJS.Worksheet,
+  sourceSheet: WorkbookSheetModel,
+  targetSheet: WorkbookSheetModel,
+  strategy: string,
+  decisionMap: Map<string, { id: string; choice: 'source' | 'target' | 'custom'; customValue?: string }>
+): void {
+  const sourceKeys = Array.from(sourceSheet.rowByKey.keys());
+  const targetKeys = new Set(targetSheet.rowByKey.keys());
+  const insertedKeys = new Map<string, number>();
