+  for (const rowKey of sourceKeys) {
+    const sourceRow = sourceSheet.rowByKey.get(rowKey);
+    const targetRow = targetSheet.rowByKey.get(rowKey);
+    const rowId = makeWorkbookDiffId(artifact.key, sheetName, rowKey, '');
+
+    if (!sourceRow) {
+      continue;
+    }
+
+    if (!targetRow) {
+      if (resolveWorkbookChoice(strategy, decisionMap.get(rowId), 'source') !== 'source') {
+        continue;
+      }
+      const insertAt = findInsertRowNumber(sourceKeys, rowKey, targetSheet, insertedKeys, targetWorksheet.rowCount);
+      targetWorksheet.spliceRows(insertAt, 0, []);
+      const targetInsertedRow = targetWorksheet.getRow(insertAt);
+      const sourceExcelRow = sourceWorksheet.getRow(sourceRow.rowIndex + 1);
+      copyRow(sourceExcelRow, targetInsertedRow);
+      insertedKeys.set(rowKey, insertAt);
+      shiftInsertedRows(insertedKeys, insertAt, rowKey);
+      shiftWorkbookModelRows(targetSheet, insertAt);
+      continue;
+    }
+
+    const targetExcelRow = targetWorksheet.getRow(targetRow.rowIndex + 1);
+    const maxColumns = Math.max(sourceRow.values.length, targetRow.values.length, sourceSheet.headers.length, targetSheet.headers.length);
+    for (let columnIndex = 0; columnIndex < maxColumns; columnIndex += 1) {
+      const sourceVal = sourceRow.values[columnIndex] ?? '';
+      const targetVal = targetRow.values[columnIndex] ?? '';
+      if (sourceVal === targetVal) {
+        continue;
+      }
+      const fieldName = sourceSheet.headers[columnIndex] || targetSheet.headers[columnIndex] || `Column ${columnIndex + 1}`;
+      const cellId = makeWorkbookDiffId(artifact.key, sheetName, `${rowKey}::${columnIndex}`, fieldName);
+      const decision = decisionMap.get(cellId);
+      const choice = resolveWorkbookChoice(strategy, decision, 'source');
+      if (choice === 'target') {
+        continue;
+      }
+      const targetCell = targetExcelRow.getCell(columnIndex + 1);
+      if (choice === 'custom') {
+        targetCell.value = decision?.customValue ?? '';
+      } else {
+        const sourceCell = sourceWorksheet.getRow(sourceRow.rowIndex + 1).getCell(columnIndex + 1);
+        targetCell.value = cloneExcelCellValue(sourceCell.value);
+      }
+    }
+  }
+
+  const deleteRows: number[] = [];
+  for (const rowKey of targetKeys) {
+    if (sourceSheet.rowByKey.has(rowKey)) {
+      continue;
+    }
+    const rowId = makeWorkbookDiffId(artifact.key, sheetName, rowKey, '');
+    if (resolveWorkbookChoice(strategy, decisionMap.get(rowId), 'target') !== 'target') {
+      const targetRow = targetSheet.rowByKey.get(rowKey);
+      if (targetRow) {
+        deleteRows.push(targetRow.rowIndex + 1);
+      }
+    }
+  }
+  deleteRows.sort((left, right) => right - left).forEach((rowNumber) => {
+    targetWorksheet.spliceRows(rowNumber, 1);
