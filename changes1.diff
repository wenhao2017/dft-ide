+async function tryMergeWorkbookArtifactWithNativeEngine(
+  artifact: CommonSyncArtifact,
+  strategy: string,
+  decisions: Array<{ id: string; choice: 'source' | 'target' | 'custom'; customValue?: string }>
+): Promise<{ used: boolean; engine?: string; error?: string }> {
+  try {
+    if (process.platform === 'win32') {
+      await mergeWorkbookWithExcelCom(artifact, strategy, decisions);
+      return { used: true, engine: 'excel-com' };
+    }
+    if (process.platform === 'linux') {
+      await mergeWorkbookWithLibreOffice(artifact, strategy, decisions);
+      return { used: true, engine: 'libreoffice' };
+    }
+  } catch (error) {
+    console.warn(
+      `Native spreadsheet merge unavailable for ${artifact.target}; falling back to ExcelJS/XLSX.`,
+      error instanceof Error ? error.message : String(error)
+    );
+    return { used: false, error: error instanceof Error ? error.message : String(error) };
+  }
+  return { used: false };
+}
+
+async function mergeWorkbookWithExcelCom(
+  artifact: CommonSyncArtifact,
+  strategy: string,
+  decisions: Array<{ id: string; choice: 'source' | 'target' | 'custom'; customValue?: string }>
+): Promise<void> {
+  const inputPath = await writeTempJson({ artifact, strategy, decisions });
+  const scriptPath = await writeTempScript('dft-excel-merge', 'ps1', getExcelComMergeScript());
+  try {
+    await runExecFile('powershell.exe', ['-NoProfile', '-ExecutionPolicy', 'Bypass', '-File', scriptPath, inputPath], path.dirname(artifact.target), 180_000);
+  } finally {
+    cleanupTempFiles(inputPath, scriptPath);
+  }
+}
+
+async function mergeWorkbookWithLibreOffice(
+  artifact: CommonSyncArtifact,
+  strategy: string,
+  decisions: Array<{ id: string; choice: 'source' | 'target' | 'custom'; customValue?: string }>
+): Promise<void> {
+  const inputPath = await writeTempJson({ artifact, strategy, decisions });
+  const scriptPath = await writeTempScript('dft-libreoffice-merge', 'py', getLibreOfficeMergeScript());
+  const escapedScript = shellQuote(scriptPath);
+  const escapedInput = shellQuote(inputPath);
+  const command = [
+    'ma libreoffice/7.6.1 >/dev/null 2>&1 || true',
+    'command -v soffice >/dev/null 2>&1',
+    `python3 ${escapedScript} ${escapedInput}`,
+  ].join(' && ');
+  try {
+    await runExecFile('bash', ['-lc', command], path.dirname(artifact.target), 240_000);
+  } finally {
+    cleanupTempFiles(inputPath, scriptPath);
+  }
+}
