+  for (const sheetName of sheetNames) {
+    const sourceSheet = sourceModels.get(sheetName);
+    const targetSheet = targetModels.get(sheetName);
+    const sourceWorksheet = sourceBook.getWorksheet(sheetName);
+    let targetWorksheet = targetBook.getWorksheet(sheetName);
+    const sheetId = makeWorkbookDiffId(artifact.key, sheetName, sheetName, '');
