+  const sourceModels = buildExcelJsWorkbookModels(sourceBook);
+  const targetModels = buildExcelJsWorkbookModels(targetBook);
+  const decisionMap = new Map(decisions.map((decision) => [decision.id, decision]));
+  const sheetNames = new Set([...sourceModels.keys(), ...targetModels.keys()]);
