{
  "name": "dft-ide",
  "displayName": "DFT IDE",
  "description": "A VS Code-based DFT workflow console for project setup, common configuration, design flow, verification flow, and backend integration.",
  "version": "0.0.1",
  "publisher": "w00445630",
  "license": "SEE LICENSE IN LICENSE",
  "preview": true,
  "categories": [
    "Other"
  ],
  "keywords": [
    "DFT",
    "IDE",
    "VS Code",
    "Design",
    "Verification"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "enabledApiProposals": [
    "terminalDataWriteEvent"
  ],
  "contributes": {
    "customEditors": [
      {
        "viewType": "dftIde.spreadsheet",
        "displayName": "DFT IDE SpreadSheet Viewer",
        "selector": [
          {
            "filenamePattern": "*.xls"
          },
          {
            "filenamePattern": "*.xlsx"
          }
        ],
        "priority": "default"
      }
    ],
    "diff": {
      "supports": [
        {
          "from": "*.xlsx",
          "to": "*.xlsx"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dftIdeExplorer",
          "title": "DFT IDE",
          "icon": "assets/activity-bar-icon.svg"
        }
      ]
    },
    "views": {
      "dftIdeExplorer": [
        {
          "id": "dftIde.views.flows",
          "name": "DFT Flows"
        }
      ]
    },
    "commands": [
      {
        "command": "dftIde.openWelcome",
        "title": "DFT IDE: Open Home"
      },
      {
        "command": "dftIde.createWorkspace",
        "title": "DFT IDE: Open Project"
      },
      {
        "command": "dftIde.createProject",
        "title": "DFT IDE: Open Project"
      },
      {
        "command": "dftIde.openFlow",
        "title": "Open DFT Flow"
      },
      {
        "command": "dftIde.applyLayout",
        "title": "DFT IDE: Apply Layout"
      },
      {
        "command": "dftIde.restoreLayout",
        "title": "DFT IDE: Restore VS Code Layout"
      },
      {
        "command": "dftIde.checkObsUpdates",
        "title": "DFT IDE: Check OBS File Updates"
      },
      {
        "command": "dftIde.manageObsUpdates",
        "title": "DFT IDE: Manage OBS File Updates"
      }
    ],
    "configuration": {
      "title": "DFT IDE",
      "properties": {
        "dftIde.apiBase": {
          "type": "string",
          "default": "http://pandas.hisi.huawei.com/dft-ide-server/",
          "description": "DFT IDE backend API base URL, for example http://localhost:8080."
        },
        "dftIde.localProjectsRoot": {
          "type": "string",
          "default": "",
          "description": "Base directory where CTMP/GitLab DFT projects are cloned locally. Project state is stored under each project root."
        },
        "dftIde.currentUser": {
          "type": "string",
          "default": "",
          "description": "Optional debug user id. Leave empty to use whoami in production-like environments, with w00445630 as the development fallback."
        },
        "dftIde.donau.mode": {
          "type": "string",
          "enum": [
            "mock",
            "real",
            "auto"
          ],
          "default": "mock",
          "description": "Donau resource loading mode. Mock is the development default; real runs dacct/dqueue/dconfig; auto falls back to mock on command errors."
        },
        "dftIde.pipeline.shellPath": {
          "type": "string",
          "default": "csh",
          "description": "Shell executable used for DFT pipeline and default-config terminals. The default flow scripts expect csh/tcsh syntax such as source, setenv and $status."
        },
        "dftIde.lastSelectedProject": {
          "type": "string",
          "default": "",
          "description": "Last selected project."
        },
        "dftIde.obs.page": {
          "type": "string",
          "default": "http://pandas.hisi.huawei.com",
          "description": "OBS service base URL (Red Zone default: http://pandas.hisi.huawei.com)."
        },
        "dftIde.obs.groupName": {
          "type": "string",
          "default": "dft",
          "description": "OBS group name used when generating fs-signature and requesting SpaceToken."
        },
        "dftIde.obs.aesKey": {
          "type": "string",
          "default": "3WB4oEodiKFUreBi",
          "description": "OBS AES-128-CBC signature key. It must be 16 bytes when encoded as UTF-8."
        },
        "dftIde.obs.aesIv": {
          "type": "string",
          "default": "aQ5TOzDq4XsumbOn",
          "description": "OBS AES-128-CBC signature IV. It must be 16 bytes when encoded as UTF-8."
        },
        "dftIde.obs.apiBasePath": {
          "type": "string",
          "default": "/file-system-server-dft",
          "description": "OBS API base path appended to dftIde.obs.page. All OBS API endpoints use this prefix."
        },
        "dftIde.obs.scriptSpace": {
          "type": "string",
          "default": "DFX_MTC001",
          "description": "OBS space name where conversion scripts are stored (leave empty to configure later)."
        },
        "dftIde.obs.scriptPaths": {
          "type": "object",
          "default": {
            "hibist": {
              "dir": "scripts/hibist",
              "files": [
                "gen_cfg.py",
                "gen_design_tree_xls2flow.py",
                "gen_dft_sig_xls2flow.py",
                "Pre_check.py",
                "XFlow_read_xls.py",
                "eco_table.py",
                "sailor_cfg_demo.json"
              ],
              "entrance": {
                "dir": "scripts/transform",
                "fileName": "run_gen_cfg"
              }
            },
            "sailor": {
              "dir": "scripts/sailor",
              "files": [
                "gen_cfg.py",
                "gen_design_tree_xls2flow.py",
                "gen_dft_sig_xls2flow.py",
                "Pre_check.py",
                "XFlow_read_xls.py",
                "eco_table.py",
                "sailor_cfg_demo.json"
              ],
              "entrance": {
                "dir": "scripts/transform",
                "fileName": "run_gen_cfg"
              }
            },
            "verification": {
              "dir": "scripts/verification",
              "files": [
                "lander_env.tar.gz"
              ],
              "entrance": {
                "dir": "scripts/transform",
                "fileName": "run_gen_lander_cfg"
              }
            }
          },
          "description": "Remote file paths of conversion scripts in the script space for each flow."
        },
        "dftIde.obs.viewerUrlTemplate": {
          "type": "string",
          "default": "{obsPage}?spaceName={spaceName}&spaceToken={spaceToken}&w3id={w3id}",
          "description": "OBS viewer URL template. Supported placeholders: {obsPage}, {spaceName}, {spaceToken}, {token}, {w3id}, {groupName}."
        },
        "dftIde.obs.w3id": {
          "type": "string",
          "default": "",
          "description": "User W3ID passed to OBS viewer URL template when needed."
        },
        "dftIde.obs.spaceName": {
          "type": "string",
          "default": "",
          "description": "Optional OBS space name override. Leave empty to use the active project name or workspace name."
        },
        "dftIde.obs.autoCheckUpdates": {
          "type": "boolean",
          "default": true,
          "description": "Check tracked OBS files for newer remote versions in the background."
        },
        "dftIde.obs.checkIntervalMinutes": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 60,
          "description": "Background OBS update-check interval in minutes."
        },
        "dftIde.obs.startupCheckDelaySeconds": {
          "type": "number",
          "default": 10,
          "minimum": 3,
          "maximum": 300,
          "description": "Delay before the first background OBS update check."
        },
        "dftIde.obs.maxConcurrentRequests": {
          "type": "number",
          "default": 4,
          "minimum": 1,
          "maximum": 8,
          "description": "Maximum concurrent OBS requests used by background update checks and directory downloads."
        },
        "dftIde.obs.requestTimeoutSeconds": {
          "type": "number",
          "default": 15,
          "minimum": 3,
          "maximum": 120,
          "description": "Timeout for individual OBS HTTP requests."
        },
        "dftIde.obs.tokenCacheSeconds": {
          "type": "number",
          "default": 60,
          "minimum": 5,
          "maximum": 600,
          "description": "Short-lived in-memory SpaceToken cache used to reduce repeated token requests."
        },
        "dftIde.layout.autoApply": {
          "type": "boolean",
          "default": false,
          "description": "Automatically apply the DFT IDE focused workbench layout on startup. Defaults to off; use the Zen Mode toggle in the webview instead."
        },
        "dftIde.layout.hideMenuBar": {
          "type": "boolean",
          "default": false,
          "description": "Hide the VS Code menu bar while using the DFT IDE layout."
        },
        "dftIde.layout.hideActivityBar": {
          "type": "boolean",
          "default": false,
          "description": "Hide the VS Code Activity Bar while using the DFT IDE layout."
        },
        "dftIde.gitlabHost": {
          "type": "string",
          "default": "http://code-dg.hisi.huawei.com/DFT_IDE_PROJECTS",
          "description": "gitlab host."
        },
        "dftIde.maxHistoryCounts": {
          "type": "number",
          "default": 5,
          "description": "max history log files."
        },
        "dftIde.filterStarProject": {
          "type": "boolean",
          "default": false,
          "description": "only show my star projects."
        }
      }
    }
  },
  "scripts": {
    "build:ext": "node scripts/build.mjs --env=production --target=ext",
    "build:worker": "node scripts/build.mjs --env=production --target=worker",
    "build:webview": "node scripts/build.mjs --env=production --target=webview",
    "compile": "npm-run-all --parallel build:ext build:webview build:worker",
    "compile:dev": "node scripts/build.mjs --env=development",
    "check": "tsc --noEmit",
    "watch:ext": "node scripts/build.mjs --env=production --target=ext --watch",
    "watch:worker": "node scripts/build.mjs --env=production --target=worker --watch",
    "watch:webview": "node scripts/build.mjs --env=production --target=webview --watch",
    "watch": "npm-run-all --parallel watch:ext watch:webview watch:worker",
    "dev": "node scripts/build.mjs --env=development --watch",
    "vscode:prepublish": "npm run compile",
    "test": "vitest run"
  },
  "dependencies": {
    "@ant-design/icons": "^5.6.1",
    "@ant-design/v5-patch-for-react-19": "^1.0.3",
    "@hookform/resolvers": "^5.0.1",
    "@tanstack/react-query": "^5.75.5",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.3",
    "@xyflow/react": "^12.10.2",
    "antd": "^5.25.1",
    "clara-xlsx-diff": "^0.1.6",
    "dagre": "^0.8.5",
    "dotenv": "^17.4.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.56.3",
    "x-data-spreadsheet": "^1.1.9",
    "xlsx": "^0.18.5",
    "yaml": "^2.9.0",
    "zod": "^3.24.4",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@types/dagre": "^0.7.54",
    "@types/node": "^18.15.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.25.3",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.9.5",
    "typescript": "^5.3.3",
    "vitest": "^1.6.0"
  }
}
