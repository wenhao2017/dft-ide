{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run DFT IDE Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--enable-proposed-api=w00445630.dft-ide",
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/out/**/*.js"
      ],
      "preLaunchTask": "npm: compile"
    },
    {
      "name": "Attach DFT IDE Extension (VSCode 1.85.1)",
      "type": "extensionHost",
      "request": "attach",
      "port": 9333,
      "outFiles": [
        "${workspaceFolder}/out/**/*.js"
      ]
    }
  ]
}
